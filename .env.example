PORT=3000
NODE_ENV=development

# Required — MongoDB Atlas (recommended) or memory for local dev without install
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/delivery-app?retryWrites=true&w=majority
# MONGODB_URI=memory
# Optional database name if omitted from URI path:
# MONGODB_DB_NAME=delivery-app

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
