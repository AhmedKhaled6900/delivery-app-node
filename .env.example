PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/delivery-app?retryWrites=true&w=majority
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Google OAuth (mobile/web idToken)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email OTP (optional in dev — OTP prints in console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@delivery.app

# SMS OTP — Twilio works in many countries (optional in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Frontend CORS (comma-separated, no quotes)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Seed admin
ADMIN_PHONE=+201000000000
ADMIN_COUNTRY_CODE=EG
ADMIN_EMAIL=admin@delivery.com
ADMIN_PASSWORD=admin123
