PORT=3000
NODE_ENV=development

# memory = no MongoDB install needed (dev only)
MONGODB_URI=memory
# MONGODB_URI=mongodb://localhost:27017/delivery-app
# Atlas example (replace USERNAME, PASSWORD, cluster host):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/delivery-app?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
